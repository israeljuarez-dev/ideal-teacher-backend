# Aplicación HTTP
APP_NAME=ideal_teacher_backend
APP_PROTOCOL=http
APP_PORT=8080
APP_ALLOWED_ORIGINS=*,http://localhost:3000
APP_ALLOWED_METHODS=POST,GET,PUT,DELETE

# Base de datos PostgreSQL
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ideal_teacher_db
DB_SSL_MODE=disable
DB_MIN_CONN=3
DB_MAX_CONN=100

# Logger
LOG_LEVEL=debug
LOG_ADD_SOURCE=false
LOG_CONSOLE_DECORATION=true 